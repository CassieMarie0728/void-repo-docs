# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MISTRAL_API_KEY: Required for Mistral AI API calls.
MISTRAL_API_KEY="MY_MISTRAL_API_KEY"

# GROQ_API_KEY: Required for Groq API calls (Llama-3.3-70b).
GROQ_API_KEY="MY_GROQ_API_KEY"

# OPENROUTER_API_KEY: Required for OpenRouter endpoint calls.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# GITHUB_TOKEN: Optional, for higher rate limits on GitHub API.
GITHUB_TOKEN="MY_GITHUB_TOKEN"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional frontend API override.
# Native Android builds default to the production Cloud Run service.
VITE_API_BASE_URL="https://void-repository-documents-320691612506.us-west2.run.app"
